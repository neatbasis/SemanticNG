{
  "version": 1,
  "quality_metric_budget": {
    "description": "No-regression baseline budget for static analysis and test stability. CI must fail if any metric exceeds baseline + allowed_regression.",
    "commands": {
      "ruff_violations": "ruff check src tests",
      "mypy_errors": "mypy --config-file=pyproject.toml src tests",
      "failing_tests": "pytest -q --maxfail=0"
    },
    "baseline": {
      "ruff_violations": 14,
      "mypy_errors": 62,
      "failing_tests": 3
    },
    "allowed_regression": {
      "ruff_violations": 0,
      "mypy_errors": 0,
      "failing_tests": 0
    },
    "governance_review": {
      "cadence": "quarterly",
      "owner": "@quality-gates",
      "raise_strictness_targets": [
        "expand_mypy_scope",
        "reduce_waivers",
        "increase_fast_test_surface"
      ]
    }
  },
  "done_capability_ids": [
    "prediction_persistence_baseline",
    "channel_agnostic_pending_obligation",
    "schema_selection_ambiguity_baseline",
    "gate_halt_unification",
    "observer_authorization_contract",
    "replay_projection_analytics",
    "invariant_matrix_coverage"
  ],
  "budget_rules": {
    "enforcement_trigger": "when_done_capability_ci_evidence_refreshes",
    "default": "zero_failing_command_packs",
    "failure_signal_field": "ci_evidence_links[].result",
    "allowed_result_values": [
      "pass",
      "fail"
    ]
  },
  "waiver_schema": {
    "required_fields": [
      "owner",
      "reason",
      "rollback_by",
      "scope"
    ],
    "scope": {
      "required_fields": [
        "capability_id",
        "command_packs"
      ],
      "command_packs": "list of exact pytest command strings or '*'"
    }
  },
  "expiry_semantics": {
    "rollback_by_format": "YYYY-MM-DD",
    "expiration_rule": "waiver is invalid once rollback_by is earlier than current UTC date",
    "timezone": "UTC"
  },
  "waivers": [],
  "baseline_update_governance": {
    "policy_doc": "docs/no_regression_budget_update_policy.md",
    "metadata_file": "docs/no_regression_budget_update_request.json",
    "default_allowed_regression": 0,
    "nonzero_allowed_regression_requires": [
      "timeboxed_exception",
      "approval_reference",
      "rollback_issue_or_pr"
    ]
  }
}
