      ],
      "precommit_hook": {
        "id": "qa-push-stage",
        "entry": "python scripts/ci/run_stage_checks.py qa-push",
        "stages": [
          "pre-push"
        ]
      }
    },
    "qa-ci": {
      "ordered_stages": [
        {
          "id": "schema-validation",
          "stop_on_fail": true,
          "commands": [
            {
              "command": "python .github/scripts/check_no_regression_budget.py",
              "timeout_seconds": 20
            },
            {
              "command": "python scripts/ci/validate_5s_mission_traceability.py",
              "timeout_seconds": 20
            },
            {
              "command": "python scripts/ci/validate_5s_metrics.py",
              "timeout_seconds": 20
            }
          ]
        },
        {
          "id": "doc-parity",
          "stop_on_fail": true,
          "commands": [
            {
              "command": "python scripts/ci/scan_unused_code.py",
              "timeout_seconds": 60
            }
          ]
        },
        {
          "id": "unit-contract-subset",
          "stop_on_fail": true,
          "commands": [
            {
              "command": "pytest -q tests/test_engine_pending_obligation.py tests/test_invariants.py tests/test_contracts_decision_effect_shape.py",
              "timeout_seconds": 80
            }
          ]
        },
        {
          "id": "heavy-suites",
          "stop_on_fail": true,
          "commands": [
            {
              "command": "pre-commit run --all-files",
              "timeout_seconds": 180
            },
            {
              "command": "pytest --cov --cov-report=term-missing --cov-report=xml",
              "timeout_seconds": 240
            },
            {
              "command": "mypy --config-file=pyproject.toml src tests",
              "timeout_seconds": 240
            }
          ]
        }
      ],
      "commands": [
        {
          "command": "python .github/scripts/check_no_regression_budget.py",
          "timeout_seconds": 20
        },
